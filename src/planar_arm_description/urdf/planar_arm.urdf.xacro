<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="planar_arm">

  <!-- ========== PARAMETERS ========== -->
  <xacro:property name="L1"        value="0.4"/>
  <xacro:property name="L2"        value="0.3"/>
  <xacro:property name="L3"        value="0.2"/>
  <xacro:property name="W"         value="0.04"/>
  <xacro:property name="H"         value="0.04"/>
  <xacro:property name="joint_lim" value="3.14159"/>
  <xacro:property name="mass_link1" value="0.5"/>
  <xacro:property name="mass_link2" value="0.3"/>
  <xacro:property name="mass_link3" value="0.15"/>

  <!-- ========== MACRO: INERTIA BOX ========== -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m*(y*y+z*z)/12}" ixy="0.0" ixz="0.0"
        iyy="${m*(x*x+z*z)/12}" iyz="0.0"
        izz="${m*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <!-- ========== MACRO: CYLINDER INERTIA ========== -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m*(3*r*r+h*h)/12}" ixy="0.0" ixz="0.0"
        iyy="${m*(3*r*r+h*h)/12}" iyz="0.0"
        izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- ========== MATERIALS ========== -->
  <material name="dark_grey">  <color rgba="0.25 0.25 0.28 1.0"/> </material>
  <material name="steel_grey"> <color rgba="0.50 0.52 0.55 1.0"/> </material>
  <material name="blue">       <color rgba="0.05 0.40 0.80 1.0"/> </material>
  <material name="green">      <color rgba="0.00 0.65 0.30 1.0"/> </material>
  <material name="red">        <color rgba="0.78 0.12 0.10 1.0"/> </material>
  <material name="yellow">     <color rgba="0.95 0.80 0.05 1.0"/> </material>
  <material name="orange">     <color rgba="0.90 0.45 0.05 1.0"/> </material>
  <material name="black">      <color rgba="0.10 0.10 0.10 1.0"/> </material>
  <material name="white">      <color rgba="0.95 0.95 0.95 1.0"/> </material>

  <!-- ========================================= -->
  <!--               BASE LINK                   -->
  <!-- ========================================= -->
  <link name="base_link">
    <visual>
      <!-- Mounting plate -->
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry><box size="0.12 0.12 0.01"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <visual>
      <!-- Lower cylinder -->
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry><cylinder radius="0.055" length="0.05"/></geometry>
      <material name="steel_grey"/>
    </visual>
    <visual>
      <!-- Upper bearing housing -->
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.03"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Collision -->
    <collision>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
      <geometry><cylinder radius="0.060" length="0.090"/></geometry>
    </collision>
    <!-- Inertia -->
    <xacro:cylinder_inertia m="1.0" r="0.055" h="0.09"/>
  </link>

  <!-- ========================================= -->
  <!--               LINK 1 (0.4 m, Blue)        -->
  <!-- ========================================= -->
  <link name="link_1">
    <visual>
      <!-- Main arm beam -->
      <origin xyz="${L1/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${L1} ${W} ${H}"/></geometry>
      <material name="blue"/>
    </visual>
    <visual>
      <!-- Proximal joint disk -->
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.028" length="0.015"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <visual>
      <!-- Distal joint disk -->
      <origin xyz="${L1} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.024" length="0.015"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Collision -->
    <collision>
      <origin xyz="${L1/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${L1} ${W} ${H}"/></geometry>
    </collision>
    <xacro:box_inertia m="${mass_link1}" x="${L1}" y="${W}" z="${H}"/>
  </link>

  <!-- ========================================= -->
  <!--               LINK 2 (0.3 m, Green)       -->
  <!-- ========================================= -->
  <link name="link_2">
    <visual>
      <!-- Main arm beam -->
      <origin xyz="${L2/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${L2} ${W} ${H}"/></geometry>
      <material name="green"/>
    </visual>
    <visual>
      <!-- Proximal joint disk -->
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.024" length="0.015"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <visual>
      <!-- Distal joint disk -->
      <origin xyz="${L2} 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.020" length="0.015"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Collision -->
    <collision>
      <origin xyz="${L2/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${L2} ${W} ${H}"/></geometry>
    </collision>
    <xacro:box_inertia m="${mass_link2}" x="${L2}" y="${W}" z="${H}"/>
  </link>

  <!-- ========================================= -->
  <!--               LINK 3 (0.2 m, Red)         -->
  <!-- ========================================= -->
  <link name="link_3">
    <visual>
      <!-- Main arm beam -->
      <origin xyz="${L3/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${L3} ${W} ${H}"/></geometry>
      <material name="red"/>
    </visual>
    <visual>
      <!-- Proximal joint disk -->
      <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
      <geometry><cylinder radius="0.020" length="0.015"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <!-- Collision -->
    <collision>
      <origin xyz="${L3/2} 0 0" rpy="0 0 0"/>
      <geometry><box size="${L3} ${W} ${H}"/></geometry>
    </collision>
    <xacro:box_inertia m="${mass_link3}" x="${L3}" y="${W}" z="${H}"/>
  </link>

  <!-- ========================================= -->
  <!--        GRIPPER BASE LINK                  -->
  <!-- ========================================= -->
  <link name="gripper_base">
    <visual>
      <origin xyz="0.015 0 0" rpy="0 0 0"/>
      <geometry><box size="0.03 0.04 0.03"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.015 0 0" rpy="0 0 0"/>
      <geometry><box size="0.03 0.04 0.03"/></geometry>
    </collision>
    <xacro:box_inertia m="0.05" x="0.03" y="0.04" z="0.03"/>
  </link>

  <!-- ========================================= -->
  <!--        GRIPPER FINGER LEFT                -->
  <!-- ========================================= -->
  <link name="gripper_finger_left">
    <visual>
      <origin xyz="0.02 0 0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.008 0.025"/></geometry>
      <material name="orange"/>
    </visual>
    <visual>
      <!-- Fingertip pad -->
      <origin xyz="0.04 0 0" rpy="0 0 0"/>
      <geometry><box size="0.008 0.012 0.025"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0.02 0 0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.008 0.025"/></geometry>
    </collision>
    <xacro:box_inertia m="0.02" x="0.04" y="0.008" z="0.025"/>
  </link>

  <!-- ========================================= -->
  <!--        GRIPPER FINGER RIGHT               -->
  <!-- ========================================= -->
  <link name="gripper_finger_right">
    <visual>
      <origin xyz="0.02 0 0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.008 0.025"/></geometry>
      <material name="orange"/>
    </visual>
    <visual>
      <!-- Fingertip pad -->
      <origin xyz="0.04 0 0" rpy="0 0 0"/>
      <geometry><box size="0.008 0.012 0.025"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0.02 0 0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.008 0.025"/></geometry>
    </collision>
    <xacro:box_inertia m="0.02" x="0.04" y="0.008" z="0.025"/>
  </link>

  <!-- ========================================= -->
  <!--        END EFFECTOR FRAME (virtual)       -->
  <!-- ========================================= -->
  <link name="end_effector">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.012"/></geometry>
      <material name="yellow"/>
    </visual>
  </link>

  <!-- ========================================= -->
  <!--                  JOINTS                   -->
  <!-- ========================================= -->

  <!-- Joint 1: base → link_1 -->
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child  link="link_1"/>
    <origin xyz="0 0 0.090" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <!-- <limit lower="${-joint_lim}" upper="${joint_lim}" effort="20.0" velocity="2.0"/>
     -->
    <limit lower="-2.967" upper="2.967" effort="20.0" velocity="2.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- Joint 2: link_1 → link_2 -->
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child  link="link_2"/>
    <origin xyz="${L1} 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <!-- <limit lower="${-joint_lim}" upper="${joint_lim}" effort="15.0" velocity="2.0"/> -->
    <limit lower="-2.268" upper="2.268" effort="15.0" velocity="2.0"/>
    <dynamics damping="0.4" friction="0.1"/>
  </joint>

  <!-- Joint 3: link_2 → link_3 -->
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child  link="link_3"/>
    <origin xyz="${L2} 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <!-- <limit lower="${-joint_lim}" upper="${joint_lim}" effort="10.0" velocity="2.0"/> -->
    <limit lower="-1.919" upper="1.919" effort="10.0" velocity="2.0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- Fixed joint: link_3 → gripper_base -->
  <joint name="gripper_base_joint" type="fixed">
    <parent link="link_3"/>
    <child  link="gripper_base"/>
    <origin xyz="${L3} 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Prismatic joint: gripper_base → finger_left -->
  <joint name="gripper_finger_left_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child  link="gripper_finger_left"/>
    <origin xyz="0 0.016 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.025" effort="5.0" velocity="0.1"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- Prismatic joint: gripper_base → finger_right (mimic left) -->
  <joint name="gripper_finger_right_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child  link="gripper_finger_right"/>
    <origin xyz="0 -0.016 0" rpy="0 0 ${pi}"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.025" effort="5.0" velocity="0.1"/>
    <dynamics damping="0.1" friction="0.05"/>
    <mimic joint="gripper_finger_left_joint" multiplier="1" offset="0"/>
  </joint>

  <!-- Fixed joint: gripper_base → end_effector -->
  <joint name="ee_fixed" type="fixed">
    <parent link="gripper_base"/>
    <child  link="end_effector"/>
    <origin xyz="0.045 0 0" rpy="0 0 0"/>
  </joint>

</robot>